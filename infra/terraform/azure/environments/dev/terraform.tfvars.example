# Copy to terraform.tfvars and adjust as needed.
# cp terraform.tfvars.example terraform.tfvars

location     = "centralus"
project_name = "legalmove-pro"
environment  = "dev"

# resource_group_name = "rg-legalmove-pro-dev"

acr_sku = "Basic"
# acr_name = "lmprodevacr0001"

# storage_account_name = "lmprodev0001"
storage_container_name            = "documents"
storage_replication_type          = "LRS"
storage_blob_soft_delete_retention_days = 7
storage_lifecycle_expire_days     = 90

servicebus_sku                    = "Standard"
servicebus_queue_name             = "analysis-jobs"
servicebus_max_delivery_count     = 5
servicebus_lock_duration          = "PT1M"
servicebus_message_ttl            = "P4D"

key_vault_sku_name                    = "standard"
key_vault_soft_delete_retention_days  = 7
key_vault_purge_protection_enabled    = false

create_managed_identities = true

# --- Block 4.C: VNet + PostgreSQL Flexible Server (private) ---
vnet_cidr                  = "10.30.0.0/16"
postgres_subnet_cidr       = "10.30.11.0/24"
container_apps_subnet_cidr = "10.30.20.0/23"

postgres_version               = "16"
postgres_sku_name              = "B_Standard_B1ms"
postgres_storage_mb            = 32768
postgres_backup_retention_days = 7
postgres_admin_username        = "legalmove"
postgres_database_name         = "legalmove"
# postgres_zone                  = "1"
postgres_high_availability_enabled = false
database_url_secret_name           = "DATABASE-URL"
# create_postgres_credentials_json_secret = true

# --- Block 4.D: Container Apps Environment ---
create_container_apps_environment = true
# log_analytics_workspace_name        = "log-legalmove-pro-dev"
# container_apps_environment_name     = "cae-legalmove-pro-dev"
log_analytics_retention_days                  = 30
container_apps_internal_load_balancer_enabled = false
container_apps_zone_redundancy_enabled        = false
container_apps_workload_profile_type          = "Consumption"

# --- Block 4.F: Container Apps (API + Worker) ---
# Push api-go:latest and worker-ai:latest to ACR before first apply (see docs/milestone-4.f-container-apps-deploy.md).
create_container_apps = true
container_image_tag   = "latest"
# api_image_name        = "api-go"
# worker_image_name     = "worker-ai"
api_min_replicas    = 1
api_max_replicas    = 2
worker_min_replicas = 1
worker_max_replicas = 1
api_cpu             = 0.5
api_memory          = "1Gi"
worker_cpu          = 1.0
worker_memory       = "2Gi"
api_port            = 8080
# --- Block 5.2: CORS para SWA — editar en terraform.tfvars (no aquí), luego terraform apply ---
# cors_allowed_origins = "http://localhost:3000,https://swa-lmpro-dev-xxxx.azurestaticapps.net"
worker_use_mock_result = false
document_temp_dir      = "/tmp/legalmove-documents"
pdf_max_bytes          = 20971520
pdf_min_text_chars     = 32
openai_api_key_secret_name = "OPENAI-API-KEY"
# Set worker_use_mock_result = true to skip OPENAI-API-KEY Key Vault reference during initial deploy.

# --- Block 4.G: SQL migrations (Container Apps Job) ---
# Push legalmove-migrations:latest to ACR before first apply (see docs/milestone-4.g-cloud-migrations-qa.md).
create_migration_job = true
# migration_image_name = "legalmove-migrations"
# migration_image_tag  = "latest"
# migration_replica_timeout_in_seconds = 300
# migration_direction  = "up"

# --- Block 5.1: Frontend — Azure Static Web Apps ---
# Run `terraform apply` to provision the SWA resource and obtain its hostname.
# Then update cors_allowed_origins above with the real SWA hostname and re-apply.
create_frontend_static_web_app   = true
# frontend_static_web_app_name   = "swa-lmpro-dev-xxxx"  # auto-generated if omitted
frontend_static_web_app_sku_tier = "Free"
frontend_static_web_app_sku_size = "Free"
