# Worker / DB (required at startup)
DATABASE_URL=postgres://legalmove:legalmove@localhost:5432/legalmove?sslmode=disable
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_USE_MOCK_RESULT=false

# Job queue (default: postgres polling; sqs dispatches/consumes via AWS SQS)
# Must match QUEUE_PROVIDER on the Go API.
QUEUE_PROVIDER=postgres

# Storage (shared with Go API)
UPLOADS_DIR=./uploads

# S3 document materialization (required when processing documents with storage_provider=s3)
# AWS credentials are loaded via standard AWS SDK chain (env vars, profile, IAM role)
AWS_REGION=us-east-1
S3_BUCKET=legalmove-pro-dev-documents
S3_PREFIX=dev
DOCUMENT_TEMP_DIR=./tmp/documents

# Azure Blob materialization (required when processing documents with storage_provider=azure_blob)
# Auth via DefaultAzureCredential (az login locally, managed identity in Azure)
# AZURE_CLIENT_ID=<worker-managed-identity-client-id>
# AZURE_STORAGE_ACCOUNT_NAME=lmprodev0001
# AZURE_STORAGE_CONTAINER_NAME=documents

# SQS queue (only when QUEUE_PROVIDER=sqs)
SQS_QUEUE_URL=
SQS_WAIT_TIME_SECONDS=10
SQS_MAX_MESSAGES=1
SQS_VISIBILITY_TIMEOUT=60

# Azure Service Bus (only when QUEUE_PROVIDER=azure_service_bus)
# AZURE_CLIENT_ID=<worker-managed-identity-client-id>
# AZURE_SERVICE_BUS_NAMESPACE=sb-lmpro-dev-xxxx
# AZURE_SERVICE_BUS_QUEUE_NAME=analysis-jobs
# AZURE_SERVICE_BUS_WAIT_TIME_SECONDS=10

# OpenAI (required only when running AI pipeline)
OPENAI_API_KEY=
OPENAI_TIMEOUT=120
OPENAI_MAX_RETRIES=2
VISION_MAX_IMAGE_BYTES=20971520
VISION_MAX_DIMENSION=8192
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TEXT_MODEL=gpt-4o

# Native PDF support (local, no cloud). Text-based PDFs are parsed locally;
# scanned/image-only PDFs are rejected with a clear message (OCR fallback TBD).
PDF_MAX_BYTES=20971520
PDF_MIN_TEXT_CHARS=32

# Langfuse (optional — pipeline runs without traces if keys are empty)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
