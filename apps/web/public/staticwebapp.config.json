{
  "routes": [
    {
      "route": "/analyses/new",
      "rewrite": "/analyses/new.html"
    },
    {
      "route": "/analyses/*",
      "rewrite": "/analyses/_.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/_next/*",
      "/favicon.ico",
      "/*.ico",
      "/*.png",
      "/*.svg",
      "/*.css",
      "/*.js"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
