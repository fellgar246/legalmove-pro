APP_ENV=local
API_PORT=8080

DATABASE_URL=postgres://legalmove:legalmove@localhost:5432/legalmove?sslmode=disable

# --- API storage (STORAGE_PROVIDER applies to Go API only) ---
UPLOADS_DIR=./uploads
STORAGE_PROVIDER=local

# S3 storage (only when STORAGE_PROVIDER=s3)
# AWS credentials are loaded via standard AWS SDK chain (env vars, profile, IAM role)
AWS_REGION=us-east-1
S3_BUCKET=legalmove-pro-dev-documents
S3_PREFIX=dev

# --- Job queue (API + worker must use the same QUEUE_PROVIDER) ---
QUEUE_PROVIDER=postgres

# SQS queue (only when QUEUE_PROVIDER=sqs)
SQS_QUEUE_URL=
SQS_WAIT_TIME_SECONDS=10
SQS_MAX_MESSAGES=1
SQS_VISIBILITY_TIMEOUT=60

# --- Worker AI pipeline ---
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_USE_MOCK_RESULT=false
DOCUMENT_TEMP_DIR=./tmp/documents
OPENAI_API_KEY=
OPENAI_TIMEOUT=120
OPENAI_MAX_RETRIES=2
VISION_MAX_IMAGE_BYTES=20971520
VISION_MAX_DIMENSION=8192
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TEXT_MODEL=gpt-4o

# Native PDF support (worker). Text-based PDFs are parsed locally;
# scanned/image-only PDFs are rejected with a clear message (OCR fallback TBD).
PDF_MAX_BYTES=20971520
PDF_MIN_TEXT_CHARS=32

# Langfuse (optional — pipeline runs without traces if keys are empty)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
